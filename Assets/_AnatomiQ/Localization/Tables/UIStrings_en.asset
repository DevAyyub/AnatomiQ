      m_Items: []
  - m_Id: 2051479432609794
    m_Localized: Tap to enable AR
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609795
    m_Localized: AnatomiQ uses your camera to place the body in the room around you.
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609796
    m_Localized: Continue
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609797
    m_Localized: Not now
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609798
    m_Localized: "Starting AR\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609799
    m_Localized: Move your phone slowly to find your surroundings.
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609800
    m_Localized: Camera access is off. Enable it in Settings to use AR.
    m_Metadata:
      m_Items: []
  - m_Id: 2051479432609801
